# Shared application environment for EC2 runtime
# Copy values into /opt/app/shared/.env on the EC2 host.

APP_ENV=production
APP_DOMAIN=example.com

# FastAPI
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000

# Next.js
NEXT_HOST=127.0.0.1
NEXT_PORT=3000
NODE_ENV=production

# Database
DATABASE_HOST=replace-with-rds-endpoint
DATABASE_PORT=5432
DATABASE_NAME=ragchat
DATABASE_USER=ragchat_admin
DATABASE_PASSWORD=replace-me
DATABASE_URL=postgresql://ragchat_admin:replace-me@replace-with-rds-endpoint:5432/ragchat

# Optional app settings
SECRET_KEY=replace-with-long-random-string
ALLOWED_ORIGINS=https://example.com
