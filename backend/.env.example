# App
APP_NAME=Multi-Tenant RAG Chatbot API
ENV=dev
DEBUG=true

# Server
HOST=127.0.0.1
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security (Sprint 2 will use these)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg://raguser:ragpass@localhost:5432/ragchat
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rag_chat
DB_USER=rag_chat
DB_PASSWORD=
